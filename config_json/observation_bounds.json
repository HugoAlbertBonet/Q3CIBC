        "flat_bounds": {
            "min": [-2.0, -2.0, -3.1416, -2.0, -2.0, -3.1416, 0.05, -0.55, 0.05, -0.55, -2.0, -2.0, -3.1416, -2.0, -2.0, -3.1416],
            "max": [ 2.0,  2.0,  3.1416,  2.0,  2.0,  3.1416, 0.80,  0.55, 0.80,  0.55,  2.0,  2.0,  3.1416,  2.0,  2.0,  3.1416]
        }
